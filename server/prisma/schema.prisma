// Prisma schema for AegisVault PostgreSQL database

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String   @map("password_hash")
  masterSalt    String   @map("master_salt")
  role          UserRole @default(USER)
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  lastLogin     DateTime? @map("last_login")

  passwords     Password[]
  documents     Document[]
  notes         Note[]
  activityLogs  ActivityLog[]
  sessions      Session[]

  @@map("users")
}

model Password {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  website          String
  username         String
  encryptedBlob    String   @map("encrypted_blob") @db.Text
  iv               String
  authTag          String   @map("auth_tag")
  url              String?
  category         String?
  expiryDate       DateTime? @map("expiry_date")
  isFavorite       Boolean  @default(false) @map("is_favorite")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  lastAccessed     DateTime? @map("last_accessed")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([website])
  @@map("passwords")
}

model Document {
  id               String       @id @default(uuid())
  userId           String       @map("user_id")
  fileName         String       @map("file_name")
  fileType         String       @map("file_type")
  fileSize         Int          @map("file_size")
  documentType     DocumentType @map("document_type")
  encryptedBlob    String       @map("encrypted_blob") @db.Text
  iv               String
  authTag          String       @map("auth_tag")
  documentNumber   String?      @map("document_number")
  expiryDate       DateTime?    @map("expiry_date")
  sha256Hash       String?      @map("sha256_hash")
  notes            String?      @db.Text
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([documentType])
  @@map("documents")
}

model Note {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  title            String
  encryptedBlob    String   @map("encrypted_blob") @db.Text
  iv               String
  authTag          String   @map("auth_tag")
  preview          String   @db.Text
  hasAudio         Boolean  @default(false) @map("has_audio")
  isRichText       Boolean  @default(false) @map("is_rich_text")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notes")
}

model ActivityLog {
  id            String       @id @default(uuid())
  userId        String       @map("user_id")
  action        ActivityAction
  resourceId    String?      @map("resource_id")
  resourceType  String?      @map("resource_type")
  ipAddress     String?      @map("ip_address")
  userAgent     String?      @map("user_agent")
  success       Boolean      @default(true)
  errorMessage  String?      @map("error_message") @db.Text
  metadata      Json?
  timestamp     DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([timestamp])
  @@map("activity_logs")
}

model Session {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  refreshToken  String   @unique @map("refresh_token")
  device        String?
  ipAddress     String?  @map("ip_address")
  userAgent     String?  @map("user_agent")
  createdAt     DateTime @default(now()) @map("created_at")
  expiresAt     DateTime @map("expires_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshToken])
  @@map("sessions")
}

enum UserRole {
  USER
  ADMIN
}

enum DocumentType {
  AADHAAR
  PAN
  MARKSHEET
  INCOME_CERTIFICATE
  CASTE_CERTIFICATE
  DOMICILE_CERTIFICATE
  CUSTOM
}

enum ActivityAction {
  LOGIN
  LOGOUT
  VAULT_UNLOCK
  PASSWORD_CREATE
  PASSWORD_READ
  PASSWORD_UPDATE
  PASSWORD_DELETE
  DOCUMENT_UPLOAD
  DOCUMENT_READ
  DOCUMENT_DOWNLOAD
  DOCUMENT_DELETE
  NOTE_CREATE
  NOTE_READ
  NOTE_UPDATE
  NOTE_DELETE
  FAILED_LOGIN
  SECURITY_SCAN
}
